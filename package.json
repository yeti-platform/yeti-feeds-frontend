{
  "name": "yeti-frontend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "build-check": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix --ignore-path .gitignore",
    "typecheck": "bash scripts/typecheck-ratchet.sh",
    "generate-api": "openapi-typescript http://localhost:8000/openapi.json -o src/services/api-schema.d.ts",
    "test:e2e": "playwright test",
    "test:e2e-ui": "playwright test --ui"
  },
  "dependencies": {
    "@date-io/moment": "^3.0.0",
    "@mdi/font": "^7.4.47",
    "@sigma/edge-curve": "^3.0.0-beta.16",
    "axios": "^1.18.1",
    "core-js": "^3.49.0",
    "dompurify": "^3.4.12",
    "graphology": "^0.25.4",
    "graphology-layout": "^0.6.1",
    "graphology-layout-force": "^0.2.4",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-layout-noverlap": "^0.4.2",
    "lodash": "^4.18.1",
    "marked": "^15.0.12",
    "mitt": "^3.0.1",
    "moment": "^2.30.1",
    "pinia": "^2.3.1",
    "roboto-fontface": "*",
    "sigma": "^3.0.3",
    "vue": "^3.5.39",
    "vue-router": "^4.6.4",
    "vuetify": "^3.12.10",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.20.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/eslint-config-typescript": "^14.9.0",
    "eslint": "^9.39.5",
    "eslint-plugin-vue": "^9.33.0",
    "openapi-typescript": "^7.13.0",
    "sass": "^1.101.0",
    "typescript": "^5.9.3",
    "unplugin-fonts": "^2.0.0",
    "vite": "^8.1.4",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-tsc": "^2.2.12"
  }
}
